<Window x:Class="ClaudeUsageTray.Presentation.Login.ClaudeLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sign in to Claude.ai"
        Width="520" Height="680"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252525" Padding="12,8">
            <StackPanel>
                <TextBlock Text="Sign in to Claude.ai to enable usage monitoring"
                           Foreground="#CCCCCC"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="12"/>
                <TextBlock x:Name="StatusLabel"
                           Text="Waiting for sign-in..."
                           Foreground="#888888"
                           FontSize="10"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <wv2:WebView2 x:Name="Browser"
                      Grid.Row="1"
                      NavigationCompleted="OnNavigationCompleted"/>

        <Border Grid.Row="2" Background="#252525" Padding="12,8">
            <Button x:Name="CancelBtn"
                    Content="Cancel"
                    HorizontalAlignment="Right"
                    Padding="14,6"
                    FontFamily="Segoe UI Variable Text, Segoe UI"
                    Click="OnCancel">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#3A3A3A"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Border>
    </Grid>
</Window>
