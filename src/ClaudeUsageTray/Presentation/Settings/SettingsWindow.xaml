<Window x:Class="ClaudeUsageTray.Presentation.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Usage — Settings"
        Width="420" Height="300"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006CBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005BA1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444444"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#484848"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" Padding="24,20">
        <StackPanel>
            <TextBlock Text="Claude.ai Account"
                       Foreground="#CCCCCC"
                       FontSize="13"
                       FontWeight="Medium"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Sign in to Claude.ai to enable real-time usage monitoring. Your session is stored securely in Windows Credential Manager."
                       Foreground="#888888"
                       FontSize="11"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <!-- Status indicator -->
            <Border x:Name="StatusBorder"
                    Background="#252525"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             VerticalAlignment="Center" Margin="0,0,8,0"
                             Fill="#888888"/>
                    <TextBlock x:Name="StatusText"
                               Text="Not signed in"
                               Foreground="#AAAAAA"
                               FontSize="11"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable Text, Segoe UI"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText"
                       Foreground="#FF6B6B"
                       FontSize="11"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SignOutBtn"
                        Content="Sign Out"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Click="OnSignOut"/>
                <Button Content="Close"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="OnClose"/>
                <Button x:Name="SignInBtn"
                        Content="Sign in to Claude.ai"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnSignIn"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
