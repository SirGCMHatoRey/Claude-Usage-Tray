<Window x:Class="ClaudeUsageTray.Presentation.Widget.FloatingWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ClaudeUsageTray.Presentation.Converters"
        Title="Claude Usage"
        Width="280" Height="178"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="OnDragMove">

    <Window.Resources>
        <conv:VisualStateToColorConverter x:Key="StateColor"/>

        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="3"
                                    Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A1A"
            CornerRadius="10"
            BorderBrush="#2D2D2D"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="16,13,16,11">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="11"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <TextBlock Text="Claude Usage"
                           Foreground="#CCCCCC"
                           FontSize="12"
                           FontWeight="Medium"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>
                <Ellipse Width="8" Height="8"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Fill="{Binding VisualState, Converter={StaticResource StateColor}}"/>
            </Grid>

            <!-- Session label row -->
            <Grid Grid.Row="2">
                <TextBlock Text="Session"
                           Foreground="#888888"
                           FontSize="10"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
                <TextBlock Text="{Binding SessionLabel}"
                           HorizontalAlignment="Right"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
            </Grid>

            <!-- Session bar -->
            <ProgressBar Grid.Row="4"
                         Value="{Binding SessionPercent, Mode=OneWay}"
                         Style="{StaticResource UsageBar}"
                         Foreground="{Binding VisualState, Converter={StaticResource StateColor}}"/>

            <!-- Session detail -->
            <TextBlock Grid.Row="6"
                       Text="{Binding SessionDetail}"
                       Foreground="#666666"
                       FontSize="9"
                       FontFamily="Segoe UI Variable Text, Segoe UI"/>

            <!-- Weekly label row -->
            <Grid Grid.Row="8">
                <TextBlock Text="Weekly"
                           Foreground="#888888"
                           FontSize="10"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
                <TextBlock Text="{Binding WeeklyLabel}"
                           HorizontalAlignment="Right"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
            </Grid>

            <!-- Weekly bar -->
            <ProgressBar Grid.Row="10"
                         Value="{Binding WeeklyPercent, Mode=OneWay}"
                         Style="{StaticResource UsageBar}"
                         Foreground="{Binding VisualState, Converter={StaticResource StateColor}}"/>

            <!-- Weekly detail -->
            <TextBlock Grid.Row="12"
                       Text="{Binding WeeklyDetail}"
                       Foreground="#666666"
                       FontSize="9"
                       FontFamily="Segoe UI Variable Text, Segoe UI"/>

            <!-- Status -->
            <TextBlock Grid.Row="14"
                       Text="{Binding StatusText}"
                       Foreground="#555555"
                       FontSize="9"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       VerticalAlignment="Bottom"/>
        </Grid>
    </Border>
</Window>
